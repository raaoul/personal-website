{
  "trailingComma": "es5",
  "tabWidth": 2,
  "semi": false,
  "singleQuote": false,
  "arrowParens": "always",
  "endOfLine": "auto",
  "printWidth": 80,
  "plugins": [
    "prettier-plugin-tailwindcss"
  ],
  "tailwindFunctions": [
    "clsx"
  ],
  "tailwindStylesheet": "./src/app/globals.css"
}